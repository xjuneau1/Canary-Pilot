# Required — get your free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — your production domain (used for OG/Twitter image URLs)
NEXT_PUBLIC_SITE_URL=https://canary-box.com

# Optional — override the sending address once your domain is verified in Resend
# Default: onboarding@resend.dev (works immediately, no domain verification needed)
RESEND_FROM_EMAIL=waitlist@canary-box.com

# Optional — override the destination address for waitlist notifications
# Default: admin@canary-box.com
RESEND_TO_EMAIL=admin@canary-box.com
